# ==================================================
# 🌍 CHAOS BRAND - PRODUCTION ENV CONFIG
# ==================================================

# --------------------------
# APP CORE
# --------------------------
VITE_APP_NAME=CHAOS BRAND
VITE_APP_ENV=production
VITE_SITE_URL=https://your-vercel-domain.vercel.app

# ==================================================
# 🔐 SUPABASE AUTH (EMAIL + GOOGLE LOGIN)
# ==================================================
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY

# Auth redirect (VERY IMPORTANT for OAuth flow)
VITE_AUTH_REDIRECT_URL=https://your-vercel-domain.vercel.app

# ==================================================
# 🔵 GOOGLE OAUTH (via Supabase or Firebase if used)
# ==================================================
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
VITE_GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_SECRET

# ==================================================
# 💳 PAYPAL (Checkout / Orders / Subscriptions)
# ==================================================
VITE_PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
VITE_PAYPAL_ENV=sandbox
# change to: live (for production)

# ==================================================
# 💳 CARD PAYMENTS (STRIPE or equivalent gateway)
# ==================================================
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_or_live_key_here

# ==================================================
# 💰 GOOGLE PAY (via Stripe or Payments API)
# ==================================================
VITE_GOOGLE_PAY_ENABLED=true
VITE_GOOGLE_PAY_MERCHANT_ID=YOUR_MERCHANT_ID

# ==================================================
# 🔐 SECURITY FLAGS
# ==================================================
VITE_ENABLE_DEBUG=false
VITE_ENABLE_MOCK_AUTH=false
VITE_ENABLE_TEST_PAYMENTS=false

# ==================================================
# 🌍 API / BACKEND (if you add later)
# ==================================================
VITE_API_BASE_URL=https://your-api.com

# ==================================================
# 🧠 COMMERCE INTELLIGENCE LAYER
# ==================================================
VITE_ENABLE_INVENTORY_SYNC=false
VITE_ENABLE_CART_SYNC=false
VITE_ENABLE_TRACKING=false
VITE_ENABLE_ABANDONED_CART=false
VITE_ENABLE_UPSELLS=false
VITE_ENABLE_LIVE_FEED=false